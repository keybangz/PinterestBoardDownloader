# Pinterest Credentials
#
# Option 1: Pinterest API (Business Account - Difficult to get approved)
# PINTEREST_APP_ID=
# PINTEREST_APP_SECRET=
# PINTEREST_ACCESS_TOKEN=
#
# Option 2: Browser Login (Recommended - no API approval needed)
# PINTEREST_USERNAME=your_email@example.com
# PINTEREST_PASSWORD=your_password

# Download Settings
OUTPUT_DIR=./downloads
MAX_CONCURRENT_DOWNLOADS=5
REQUEST_TIMEOUT=30
CONNECT_TIMEOUT=10
MAX_RETRIES=3
CHUNK_SIZE=65536

# Advanced Settings
VERIFY_DUPLICATES=true
VERIFY_SSL=true
RATE_LIMIT_DELAY=0.1
MAX_HASH_CACHE_SIZE=10000
MIN_FREE_DISK_MB=100
MAX_FILE_SIZE_MB=500
USER_AGENT=PinterestBoardDownloader/1.0.0
